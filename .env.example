# Runtime
NODE_ENV=development
PORT=3000
HOST=127.0.0.1
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://meta_ads:meta_ads@localhost:5432/meta_ads_dev

# Meta Graph API
META_API_VERSION=v21.0
META_APP_ID=
META_APP_SECRET=
# Source IDs for engagement-based custom audiences (omit to disable IG/FB engagers)
META_PAGE_ID=
META_IG_BUSINESS_ID=

# Token validation cadence
TOKEN_VALIDATE_INTERVAL_MIN=30

# Insight snapshot freshness window (re-use cached snapshot if newer than this)
INSIGHT_SNAPSHOT_TTL_MIN=60

# KIE.ai image generation
KIE_API_BASE_URL=https://api.kie.ai
# Public callback URL (set when our service is internet-reachable)
KIE_CALLBACK_URL=
# How long to consider KIE-hosted result URLs valid (best estimate)
KIE_ASSET_DEFAULT_TTL_DAYS=14
# Interval for batch polling of pending KIE tasks
KIE_POLL_INTERVAL_SEC=30

# Internal dashboard (omit password/secret to disable the dashboard)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
# Must be at least 32 characters; generate via: openssl rand -hex 32
DASHBOARD_SESSION_SECRET=
DASHBOARD_SESSION_TTL_HOURS=24

# Telegram bot (omit token/chat to disable bot + notifications)
TELEGRAM_BOT_TOKEN=
# Numeric chat ID of the owner DM (always receives notifications + can approve)
TELEGRAM_CHAT_ID=
# Optional group chat where notifications are mirrored and read commands are allowed.
# Negative number for groups/supergroups. Bot must be added to the group.
TELEGRAM_GROUP_CHAT_ID=
# Comma-separated list of Telegram user IDs allowed to approve writes.
# Other members in the allowed chats can still use read commands.
TELEGRAM_APPROVED_USER_IDS=

# Auto-optimizer thresholds (CPR in major currency units, e.g. IDR rupiah)
OPTIMIZER_AUTO_PAUSE_CPR_IDR=75000
OPTIMIZER_AUTO_SCALE_CPR_IDR=20000
OPTIMIZER_AUTO_PAUSE_MIN_DAYS=2
OPTIMIZER_RESUME_NOTIFY_DAYS=3
OPTIMIZER_AUDIT_WINDOW_DAYS=7
# Currency minor units per major unit (IDR/JPY = 1, USD = 100, etc.)
OPTIMIZER_CURRENCY_MINOR_PER_UNIT=100

# Anthropic Claude API (powers natural-language Q&A in the Telegram bot)
# Omit to disable AI; slash commands keep working without it.
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-5
AI_MAX_TOKENS=1500

# Google Sheets API (service account JSON path; share each sheet with the SA email)
GOOGLE_CREDENTIALS_PATH=./config/google-credentials.json
